  - textId: 422
    languageType: 0
    text: "\uCE58\uBA85\uD0C0 \uD53C\uD574\uAC00 10% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 423
    languageType: 0
    text: "\uCE58\uBA85\uD0C0 \uD53C\uD574\uAC00 10% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 424
    languageType: 0
    text: "\uCE58\uBA85\uD0C0 \uD53C\uD574\uAC00 10% \uC99D\uAC00\uD569\uB2C8\uB2E4."
