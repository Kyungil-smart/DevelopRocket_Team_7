  - textId: 413
    languageType: 0
    text: "\uACF5\uACA9\uB825\uC774 10% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 414
    languageType: 0
    text: "\uACF5\uACA9\uB825\uC774 20% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 415
    languageType: 0
    text: "\uACF5\uACA9\uB825\uC774 30% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 416
    languageType: 0
    text: "\uACF5\uACA9\uC18D\uB3C4\uAC00 10% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 417
    languageType: 0
    text: "\uACF5\uACA9\uC18D\uB3C4\uAC00 15% \uC99D\uAC00\uD569\uB2C8\uB2E4."
  - textId: 418
    languageType: 0
    text: "\uACF5\uACA9\uC18D\uB3C4\uAC00 20% \uC99D\uAC00\uD569\uB2C8\uB2E4."
